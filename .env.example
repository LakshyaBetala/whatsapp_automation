# Copy to .env and fill in. Never commit .env.

# --- Supabase ---
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Service-role key (backend only — bypasses RLS). Keep secret.
SUPABASE_SERVICE_KEY=
# Direct Postgres connection string (for running migrations with psql)
SUPABASE_DB_URL=

# --- AiSensy (WhatsApp BSP) ---
AISENSY_API_KEY=
AISENSY_API_BASE=https://backend.aisensy.com
# Shared secret you set on the AiSensy webhook to verify inbound calls
AISENSY_WEBHOOK_SECRET=

# --- OpenWA (WhatsApp Node microservice, wa_service/) ---
# Where the backend reaches the OpenWA sender. Local dev default below;
# in production point this at the machine running wa_service.
OPENWA_URL=http://localhost:3001
# Optional SECOND session (our company number) for owner-facing messages:
# digest, alerts, renewal notices. Run start_platform_wa.bat (port 3002),
# scan its QR with the company WhatsApp, then uncomment:
# PLATFORM_WA_URL=http://localhost:3002

# --- App ---
APP_ENV=development
TIMEZONE=Asia/Kolkata
# Token the Tally agent sends in the Authorization header when pushing data
TALLY_AGENT_TOKEN=change-me
# Public base URL of THIS backend (used to build keep-alive ping + UPI links)
PUBLIC_BASE_URL=http://localhost:8000

# --- Scheduling (24h clock, in TIMEZONE) ---
EOD_DIGEST_HOUR=22
EOD_DIGEST_MINUTE=0
REMINDER_SWEEP_HOUR=10
REMINDER_SWEEP_MINUTE=0

# --- AI (optional, Phase 2/3) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
