# Copy to .env and fill in. Never commit .env.

# --- Supabase ---
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Service-role key (backend only — bypasses RLS). Keep secret.
SUPABASE_SERVICE_KEY=
# Direct Postgres connection string (for running migrations with psql)
SUPABASE_DB_URL=

# --- AiSensy (WhatsApp BSP) ---
AISENSY_API_KEY=
AISENSY_API_BASE=https://backend.aisensy.com
# Shared secret you set on the AiSensy webhook to verify inbound calls
AISENSY_WEBHOOK_SECRET=

# --- OpenWA (WhatsApp Node microservice, wa_service/) ---
# Two numbers, two wa_service instances (both on the 24/7 host laptop):
#   3001 = SHOP number -> bills, reminders, customer replies (customer-facing)
#   3002 = ASVA BOT number -> owner-only assistant (LIST, BILL, photo, digest)
# Start the bot instance with:
#   set PORT=3002 & set SESSION_ID=bot & set WA_CHANNEL=bot & node index.js
OPENWA_URL=http://localhost:3001
# Owner-facing sends (digest, alerts) use the "platform" channel -> bot number:
PLATFORM_WA_URL=http://localhost:3002

# --- App ---
APP_ENV=development
TIMEZONE=Asia/Kolkata
# Operator secret for the Command Center (/ops) and subscription actions
# (/license/renew, /license/suspend, /license/set-plan). The CLIENT never uses
# this - only you. While it is EMPTY, all ops endpoints refuse. Set a long
# random value on the always-on host, e.g. a 32-char token.
ADMIN_API_KEY=
# Token the Tally agent sends in the Authorization header when pushing data
TALLY_AGENT_TOKEN=change-me
# Public base URL of THIS backend (used to build keep-alive ping + UPI links)
PUBLIC_BASE_URL=http://localhost:8000

# --- Scheduling (24h clock, in TIMEZONE) ---
EOD_DIGEST_HOUR=22
EOD_DIGEST_MINUTE=0
REMINDER_SWEEP_HOUR=10
REMINDER_SWEEP_MINUTE=0

# --- AI (optional, Phase 2/3) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
